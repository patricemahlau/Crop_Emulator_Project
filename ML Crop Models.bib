@article{huClimateChangeImpacts2024,
  title = {Climate Change Impacts on Crop Yields: {{A}} Review of Empirical Findings, Statistical Crop Models, and Machine Learning Methods},
  shorttitle = {Climate Change Impacts on Crop Yields},
  author = {Hu, Tongxi and Zhang, Xuesong and Khanal, Sami and Wilson, Robyn and Leng, Guoyong and Toman, Elizabeth M. and Wang, Xuhui and Li, Yang and Zhao, Kaiguang},
  year = 2024,
  month = aug,
  journal = {Environmental Modelling \& Software},
  volume = {179},
  pages = {106119},
  issn = {1364-8152},
  doi = {10.1016/j.envsoft.2024.106119},
  urldate = {2026-04-15},
  abstract = {Understanding crop responses to climate change is crucial for ensuring food security. Here, we reviewed {$\sim$}230 statistical crop modeling studies for major crops and summarized recent progress in estimating climate change impacts on crop yields. Evidence was strong that increasing temperatures reduce crop yields. A 1~{$^\circ$}C warming decreased the yields by 7.5~\textpm ~5.3\% (maize), 6.0~\textpm ~3.3\% (wheat), 6.8~\textpm ~5.9\% (soybean), and 1.2~\textpm 5.2\% (rice) across the world, but spatial heterogeneity was noticeable, due partly to asymmetric nonlinear crop responses to temperature (e.g., warming-induced gains in cold regions). Yield responses to precipitation were not consistent across the studies or geographical areas. On average, climate explained 37\% of yield variability. We also observed a methodological shift from linear regression to machine learning (e.g., explainable AI and interpretable machine learning), which on average reduced predictve errors by 44\%. Furthermore, we discussed the opportunities and challenges facing statistical crop modeling, such as ensemble modeling, physics-informed machine learning, spatiotemporal heterogeneity in crop responses, climate extremes, extrapolation under novel climates, and the confounding from technology, management, CO2, and O3.},
  keywords = {Agriculture 5.0,Climate change,Digital Twin,Food security,Global Warming,Machine learning,Process-based models,review,Statistical crop models},
  file = {/Users/patricemahlau/Zotero/storage/4PADF2CD/Hu et al. - 2024 - Climate change impacts on crop yields A review of empirical findings, statistical crop models, and.pdf;/Users/patricemahlau/Zotero/storage/9GX66M5H/S1364815224001804.html}
}

@article{iniyanCropYieldPrediction2023,
  title = {Crop Yield Prediction Using Machine Learning Techniques},
  author = {Iniyan, S and Akhil Varma, V and Teja Naidu, Ch},
  year = 2023,
